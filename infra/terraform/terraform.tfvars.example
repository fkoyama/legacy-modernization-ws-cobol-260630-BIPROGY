# terraform.tfvars のサンプル。必要に応じて値を変更し terraform.tfvars にコピーして使用。
# cp terraform.tfvars.example terraform.tfvars

prefix   = "pbwscobol"
location = "japaneast"

# ---- PostgreSQL ----
pg_admin_user     = "pgadmin"
pg_admin_password = "Workshop_Passw0rd!" # ワークショップ用。実運用では必ず変更。
pg_db_name        = "banking"
pg_sku_name       = "B_Standard_B1ms"
pg_storage_mb     = 32768
pg_version        = "15"

# ---- Container App ----
# 空文字列の場合は ACR 上の sample-accounts:latest を使用。他イメージを使う場合は <acr_login_server>/<repo>:<tag> を指定。
container_image        = ""
container_target_port  = 8080
container_min_replicas = 0
container_max_replicas = 1
